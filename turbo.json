{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "ENABLE_EXPERIMENTAL_COREPACK"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "build:registry": {
      "outputs": ["apps/docs/public/r/**"]
    }
  }
}
